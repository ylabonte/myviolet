{
  "name": "myviolet",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",
  "postCreateCommand": "pip install -e '.[dev,test,docs]' && pre-commit install",
  "postStartCommand": "nohup python -m tools.myviolet_mock > /tmp/myviolet-mock.log 2>&1 &",
  "forwardPorts": [8080, 8000],
  "portsAttributes": {
    "8080": {
      "label": "Violet Mock",
      "onAutoForward": "notify"
    },
    "8000": {
      "label": "MkDocs Preview",
      "onAutoForward": "silent"
    }
  },
  "remoteEnv": {
    "MYVIOLET_MOCK_HOST": "0.0.0.0",
    "MYVIOLET_MOCK_PORT": "8080"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "github.vscode-github-actions"
      ],
      "settings": {
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports.ruff": "explicit"
          }
        },
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
